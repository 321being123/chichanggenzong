# ===== 持仓管理系统 环境变量模板 =====
# 复制本文件为 .env 后，按需填写（.env 已被 .gitignore 忽略，不会上传）
# 应用启动时会通过 dotenv 自动读取本文件（放到项目根目录，与 server.js 同级）

# 服务监听端口（Nginx 反代会指向这个内部端口，公网无需开放）
PORT=3000

# 会话密钥：生产环境务必改成一个随机长字符串（可用 `openssl rand -hex 32` 生成）
# 若 data/.secret 已存在且非空，则此处留空也会自动沿用
SECRET=

# 允许的请求来源（部署公网后必填，多个用逗号分隔，只写域名，不要带 http/端口）
# 本地默认：localhost,127.0.0.1
# 上线后改为你的域名，例如：myapp.com,www.myapp.com
ALLOWED_ORIGIN=localhost,127.0.0.1

# 注册邀请码：设置后，新用户注册必须填此码；不设置则任何人可自助注册
# 公网部署强烈建议设置一个
REGISTER_CODE=

# ===== PostgreSQL 连接（二选一） =====
# 方式A：完整连接串（优先）。例如 postgres://用户名:密码@主机:5432/库名
DATABASE_URL=postgres://postgres:密码@localhost:5432/portfolio
# 方式B：分项变量（未设置 DATABASE_URL 时生效）
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=portfolio
# 如数据库启用 SSL（云数据库常见），设 true；本地一般 false
PGSSL=false

